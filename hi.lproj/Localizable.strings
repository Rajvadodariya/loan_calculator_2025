/* Stamp Duty Basis Descriptions */
"stamp_duty_basis_usa" = "संपत्ति हस्तांतरण कर (देश के अनुसार भिन्न).\n• USA राज्य के अनुसार भिन्न.\n• आमतौर पर 0.01% से 4%.\n• कुछ राज्यों में कोई हस्तांतरण कर नहीं है.";
"stamp_duty_basis_canada" = "भूमि हस्तांतरण कर.\n• संघीय: कोई संघीय कर नहीं.\n• प्रांतीय: व्यापक रूप से भिन्न.\n• पहली बार खरीदारों को छूट मिल सकती है.";
"stamp_duty_basis_mexico" = "Impuesto sobre Adquisición de Inmuebles.\n• आमतौर पर 2% से 5%.\n• राज्य के अनुसार भिन्न.\n• नोटरी शुल्क शामिल हो सकता है.";
"stamp_duty_basis_india" = "स्टाम्प शुल्क और पंजीकरण.\n• रेंज: 3% से 7% (राज्य के अनुसार भिन्न).\n• पंजीकरण शुल्क: ~1% अतिरिक्त.\n• महिलाओं को कुछ राज्यों में छूट मिल सकती है.";
"stamp_duty_basis_indonesia" = "BPHTB (हस्तांतरण कर).\n• फॉर्मूला: (संपत्ति मूल्य - NPOPTKP) * 5%.\n• NPOPTKP: कर-मुक्त सीमा.\n• सभी हस्तांतरणों के लिए अनिवार्य.";
"stamp_duty_basis_uk" = "SDLT (स्टाम्प शुल्क).\n• पहले £250,000 पर 0%.\n• £250,001 - £925,000 पर 5%.\n• £925,001 - £1.5M पर 10%.\n• £1.5M से ऊपर 12%.";
"stamp_duty_basis_australia" = "राज्य-आधारित हस्तांतरण शुल्क.\n• रेंज: लगभग 1.25% से 5.5%.\n• NSW: पहली बार खरीदारों के लिए $800k छूट.\n• राज्य के अनुसार भिन्न.";
"stamp_duty_basis_germany" = "Grunderwerbsteuer (संपत्ति हस्तांतरण कर).
