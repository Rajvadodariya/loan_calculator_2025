"stamp_duty_basis_india" = "Droit de Timbre et Enregistrement.\n• Plage: 3% à 7% (varie selon l'État).\n• Frais d'Enregistrement: ~1% supplémentaire.\n• Les femmes peuvent recevoir des tarifs réduits.";
"stamp_duty_basis_indonesia" = "BPHTB (Taxe de Transfert).\n• Formule: (Valeur de Propriété - NPOPTKP) * 5%.\n• NPOPTKP: Seuil d'exonération fiscale.\n• Obligatoire pour tous les transferts.";
"stamp_duty_basis_uk" = "SDLT (Taxe de Timbre).\n• 0% sur les premiers £250,000.\n• 5% sur £250,001 - £925,000.\n• 10% sur £925,001 - £1.5M.\n• 12% au-dessus de £1.5M.";
"stamp_duty_basis_australia" = "Taxe de Transfert d'État.\n• Plage: Env. 1.25% à 5.5%.\n• NSW: $800k exemption pour premiers acheteurs.\n• Varie selon l'État.";
"stamp_duty_basis_germany" = "Grunderwerbsteuer (Droits de transfert immobilier).
