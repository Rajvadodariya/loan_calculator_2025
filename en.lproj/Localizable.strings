/* Stamp Duty Basis Descriptions */
"stamp_duty_basis_usa" = "Property Transfer Tax (varies by country).\n• USA varies by state.\n• Typically 0.01% to 4% (real estate transfer tax).\n• Some states have no transfer tax.";
"stamp_duty_basis_canada" = "Land Transfer Tax.\n• Federal: No federal transfer tax.\n• Provincial: Varies widely, e.g., Ontario has tiered rates from 0.5% to 2.5%.\n• First-time buyers may receive rebates.";
"stamp_duty_basis_mexico" = "Impuesto sobre Adquisición de Inmuebles.\n• Typically 2% to 5% of property value.\n• Varies by state.\n• May include notary fees.";
"stamp_duty_basis_india" = "Stamp Duty & Registration.\n• Range: 3% to 7% of property value (varies by state).\n• Registration Fee: ~1% extra.\n• Women may receive discounted rates in some states.";
"stamp_duty_basis_indonesia" = "BPHTB (Bea Perolehan Hak atas Tanah dan Bangunan).\n• Formula: (Property Value - NPOPTKP) * 5%.\n• NPOPTKP: Tax-free threshold varies by city (typically Rp 60,000,000).\n• Mandatory for all property transfers.";
"stamp_duty_basis_uk" = "SDLT (Stamp Duty Land Tax).\n• 0% on first £250,000.\n• 5% on £250,001 - £925,000.\n• 10% on £925,001 - £1.5M.\n• 12% above £1.5M.\n• First-time buyers: 0% up to £425,000 for homes under £625k.";
"stamp_duty_basis_australia" = "State-based Transfer Duty (Stamp Duty).\n• Range: Approx 1.25% to 5.5% (tiered by value).\n• NSW Example: $800k full exemption (0%) for first-home buyers.\n• Varies by state (VIC, QLD, WA have different caps).";
"stamp_duty_basis_germany" = "Grunderwerbsteuer (Property Transfer Tax).\n• Rate: 3.5% to 6.5% (varies by Bundesland).\n• Bavaria & Saxony: 3.5%. Berlin & Hesse: 6%.\n• App uses 5% average. Enter custom rate for your state.";
"stamp_duty_basis_france" = "Droits de Mutation (À Titre Onéreux).\n• Rate: ≈5.806% for existing properties.\n• Includes département, state, and commune tax.\n• New builds: TVA (20%) replaces transfer tax.";

